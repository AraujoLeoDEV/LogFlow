// Prisma schema - Sistema de Logistica e Controle de Frota
// Convenção (seção 6 do CLAUDE.md): tabelas/colunas em snake_case via @@map/@map,
// atributos do model em camelCase, enums em UPPER_SNAKE_CASE.

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// Perfis de acesso (RBAC) - seção 4.1
enum Role {
  ADMIN
  COORDENACAO
  MOTORISTA
  FINANCEIRO
  CONFERENTE
}

// Tipos de combustível dos veículos - seção 4.3 / 4.6
enum FuelType {
  GASOLINE
  ETHANOL
  DIESEL
  FLEX
  GNV
}

// Status do registro diário de uso da frota - seções 4.4 e 4.5
enum DailyLogStatus {
  EM_ANDAMENTO
  FINALIZADO
  ATRASADO
}

// Tipo de manutenção - seção 4.7
enum MaintenanceType {
  PREVENTIVA
  CORRETIVA
}

// Categoria de manutenção - define qual campo next* do Vehicle é
// recalculado ao concluir o registro - seção 4.7
enum MaintenanceCategory {
  TROCA_OLEO
  TROCA_PNEUS
  REVISAO_GERAL
  OUTROS
}

// Categoria da ocorrência (classificação ampla, usada em filtros e
// indicadores) - seção 4.8
enum IncidentCategory {
  TRANSITO
  SINISTRO
  MECANICA
  OPERACIONAL
  OUTROS
}

// Tipo da ocorrência (classificação específica - "Exemplos de tipo" da
// seção 4.8: multa, acidente, pane, atraso, dano ao veículo)
enum IncidentType {
  MULTA
  ACIDENTE
  PANE
  ATRASO
  DANO_VEICULO
  OUTROS
}

// Gravidade da ocorrência - seção 4.8
enum IncidentSeverity {
  BAIXA
  MEDIA
  ALTA
  CRITICA
}

// Status do envio (protocolo) - seção 4.9
enum ShipmentStatus {
  PENDENTE
  EM_TRANSITO
  ENTREGUE
  CANCELADO
  CONFIRMADO
}

// Criticidade do envio, definida por quem cria o envio
enum ShipmentPriority {
  URGENTE
  MODERADO
  BAIXO
}

// Unidade de medida do item do envio - seção 4.9
enum ShipmentItemUnit {
  UND
  CX
  ML
  L
}

// Tipo de arquivo gerado/anexado a um envio - seção 4.9
enum ShipmentFileType {
  PDF
  PHOTO
}

// Tipo de alerta automático - seção 4.10
enum AlertType {
  LICENSING
  INSURANCE
  CNH
  REVIEW
  OIL_CHANGE
  TIRE_CHANGE
  TRIP_DELAYED
  SHIPMENT_CREATED
}

// Gravidade do alerta - seção 4.10
enum AlertSeverity {
  INFO
  AVISO
  CRITICO
}

// Status do alerta (controle de envio/leitura) - seção 4.10
enum AlertStatus {
  PENDENTE
  ENVIANDO
  ENVIADO
  LIDO
}

// Tipo de meta - seção 4.13
enum GoalType {
  CONSUMPTION_REDUCTION
}

// Status da meta - seção 4.13
enum GoalStatus {
  ABERTA
  ATINGIDA
  NAO_ATINGIDA
}

// Tipos de relatório exportável - seção 4.14
enum ReportType {
  DAILY_USAGE
  VEHICLE_HISTORY
  DRIVER_HISTORY
  MONTHLY_COSTS
  FUEL
  MAINTENANCE
  INCIDENTS
  SAVINGS
  RANKING
}

// Formato de exportação - seção 4.14
enum ReportFormat {
  PDF
  EXCEL
  CSV
}

// Status do job de geração do relatório - seção 4.14
enum ReportStatus {
  PENDING
  PROCESSING
  DONE
  ERROR
}

// Usuários do sistema - seção 4.1
model User {
  id                  String    @id @default(uuid())
  name                String
  email               String    @unique
  passwordHash        String    @map("password_hash")
  role                Role
  isActive            Boolean   @default(true) @map("is_active")
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")
  unitId              String?   @map("unit_id")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  unit                Unit?                @relation(fields: [unitId], references: [id])
  driver              Driver?
  sentShipments       Shipment[]           @relation("ShipmentSender")
  shipmentReceipts    ShipmentReceipt[]
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

// Unidades de destino dos envios - seção 4.2 / 4.9 (usado também na Fase 8)
model Unit {
  id        String   @id @default(uuid())
  name      String
  address   String
  phone     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users                  User[]
  shipmentsAsOrigin      Shipment[] @relation("ShipmentOrigin")
  shipmentsAsDestination Shipment[] @relation("ShipmentDestination")

  @@map("units")
}

// Rotas - seção 4.2
model Route {
  id                       String   @id @default(uuid())
  name                     String
  estimatedDistanceKm      Decimal  @map("estimated_distance_km") @db.Decimal(10, 2)
  estimatedDurationMinutes Int      @map("estimated_duration_minutes")
  active                   Boolean  @default(true)
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  vehicles  Vehicle[]  @relation("VehicleMainRoute")
  drivers   Driver[]   @relation("DriverDefaultRoute")
  dailyLogs DailyLog[]

  @@map("routes")
}

// Veículos - seção 4.3
model Vehicle {
  id                  String    @id @default(uuid())
  plate               String    @unique
  model               String
  fuelType            FuelType  @map("fuel_type")
  tankCapacityLiters  Decimal   @map("tank_capacity_liters") @db.Decimal(10, 2)
  yearModel           Int       @map("year_model")
  mainRouteId         String?   @map("main_route_id")
  acquisitionValue    Decimal   @map("acquisition_value") @db.Decimal(12, 2)
  usefulLifeMonths    Int       @map("useful_life_months")
  residualValue       Decimal   @map("residual_value") @db.Decimal(12, 2)
  currentKm           Decimal   @default(0) @map("current_km") @db.Decimal(10, 1)
  licensingExpiration DateTime? @map("licensing_expiration")
  insuranceExpiration DateTime? @map("insurance_expiration")
  active              Boolean   @default(true)
  // Próximas manutenções previstas - seção 4.7 (base para alertas da Fase 9)
  nextOilChangeKm     Decimal?  @map("next_oil_change_km") @db.Decimal(10, 1)
  nextOilChangeDate   DateTime? @map("next_oil_change_date")
  nextTireChangeKm    Decimal?  @map("next_tire_change_km") @db.Decimal(10, 1)
  nextTireChangeDate  DateTime? @map("next_tire_change_date")
  nextReviewKm        Decimal?  @map("next_review_km") @db.Decimal(10, 1)
  nextReviewDate      DateTime? @map("next_review_date")
  createdBy           String?   @map("created_by")
  updatedBy           String?   @map("updated_by")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  mainRoute    Route?        @relation("VehicleMainRoute", fields: [mainRouteId], references: [id])
  drivers      Driver[]
  dailyLogs    DailyLog[]
  fuelRecords  Fuel[]
  maintenances Maintenance[]
  incidents    Incident[]
  goals        Goal[]

  @@map("vehicles")
}

// Motoristas - seção 4.2
model Driver {
  id             String    @id @default(uuid())
  name           String
  position       String
  vehicleId      String?   @map("vehicle_id")
  currentKm      Decimal   @default(0) @map("current_km") @db.Decimal(10, 1)
  defaultRouteId String?   @map("default_route_id")
  cnhExpiration  DateTime? @map("cnh_expiration")
  userId         String?   @unique @map("user_id")
  active         Boolean   @default(true)
  createdBy      String?   @map("created_by")
  updatedBy      String?   @map("updated_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  vehicle              Vehicle?   @relation(fields: [vehicleId], references: [id])
  defaultRoute         Route?     @relation("DriverDefaultRoute", fields: [defaultRouteId], references: [id])
  user                 User?      @relation(fields: [userId], references: [id])
  dailyLogs            DailyLog[]
  fuelRecords          Fuel[]
  incidents            Incident[]
  transportedShipments Shipment[] @relation("ShipmentTransporter")
  goals                Goal[]

  @@map("drivers")
}

// Registro diário de uso da frota (saída/retorno) - seções 4.4 e 4.5
model DailyLog {
  id                   String         @id @default(uuid())
  vehicleId            String         @map("vehicle_id")
  driverId             String         @map("driver_id")
  routeId              String         @map("route_id")
  departureAt          DateTime       @map("departure_at")
  returnAt             DateTime?      @map("return_at")
  startKm              Decimal        @map("start_km") @db.Decimal(10, 1)
  endKm                Decimal?       @map("end_km") @db.Decimal(10, 1)
  kmDriven             Decimal?       @map("km_driven") @db.Decimal(10, 1)
  totalDurationMinutes Int?           @map("total_duration_minutes")
  avgSpeedKmh          Decimal?       @map("avg_speed_kmh") @db.Decimal(10, 2)
  destination          String?
  observations         String?
  status               DailyLogStatus @default(EM_ANDAMENTO)
  createdBy            String?        @map("created_by")
  updatedBy            String?        @map("updated_by")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  driver  Driver  @relation(fields: [driverId], references: [id])
  route   Route   @relation(fields: [routeId], references: [id])

  @@map("daily_logs")
}

// Abastecimento - seção 4.6
model Fuel {
  id             String   @id @default(uuid())
  vehicleId      String   @map("vehicle_id")
  driverId       String   @map("driver_id")
  liters         Decimal  @db.Decimal(10, 2)
  amountPaid     Decimal  @map("amount_paid") @db.Decimal(10, 2)
  currentKm      Decimal  @map("current_km") @db.Decimal(10, 1)
  fuelType       FuelType @map("fuel_type")
  date           DateTime @default(now())
  consumptionKmL Decimal? @map("consumption_km_l") @db.Decimal(10, 3)
  costPerKm      Decimal? @map("cost_per_km") @db.Decimal(10, 4)
  createdBy      String?  @map("created_by")
  updatedBy      String?  @map("updated_by")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  driver  Driver  @relation(fields: [driverId], references: [id])

  @@map("fuel_records")
}

// Manutenção - seção 4.7
model Maintenance {
  id            String              @id @default(uuid())
  vehicleId     String              @map("vehicle_id")
  type          MaintenanceType
  category      MaintenanceCategory
  km            Decimal             @db.Decimal(10, 1)
  cost          Decimal             @db.Decimal(10, 2)
  description   String
  scheduledDate DateTime?           @map("scheduled_date")
  scheduledKm   Decimal?            @map("scheduled_km") @db.Decimal(10, 1)
  performedDate DateTime?           @map("performed_date")
  createdBy     String?             @map("created_by")
  updatedBy     String?             @map("updated_by")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@map("maintenances")
}

// Ocorrências - seção 4.8
model Incident {
  id           String           @id @default(uuid())
  vehicleId    String           @map("vehicle_id")
  driverId     String           @map("driver_id")
  category     IncidentCategory
  type         IncidentType
  severity     IncidentSeverity
  responsible  String
  cost         Decimal?         @db.Decimal(10, 2)
  observations String
  date         DateTime
  createdBy    String?          @map("created_by")
  updatedBy    String?          @map("updated_by")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  driver  Driver  @relation(fields: [driverId], references: [id])

  @@map("incidents")
}

// Contador atômico para geração do número de protocolo (AAAAMMDD-SEQ) dos
// envios - seção 4.9. Uma linha por dia; "lastSeq" é incrementado via
// `INSERT ... ON CONFLICT DO UPDATE` (atômico mesmo sob concorrência).
model ProtocolCounter {
  date    String @id
  lastSeq Int    @default(0) @map("last_seq")

  @@map("protocol_counters")
}

// Envios de itens entre unidades, identificados por protocolo único - seção 4.9
model Shipment {
  id                String           @id @default(uuid())
  protocolNumber    String           @unique @map("protocol_number")
  originUnitId      String?          @map("origin_unit_id")
  destinationUnitId String           @map("destination_unit_id")
  senderId          String           @map("sender_id")
  transporterId     String?          @map("transporter_id")
  shippedAt         DateTime         @default(now()) @map("shipped_at")
  observations      String?
  status            ShipmentStatus   @default(PENDENTE)
  priority          ShipmentPriority @default(MODERADO)
  createdBy         String?          @map("created_by")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  originUnit      Unit?                   @relation("ShipmentOrigin", fields: [originUnitId], references: [id])
  destinationUnit Unit                    @relation("ShipmentDestination", fields: [destinationUnitId], references: [id])
  sender          User                    @relation("ShipmentSender", fields: [senderId], references: [id])
  transporter     Driver?                 @relation("ShipmentTransporter", fields: [transporterId], references: [id])
  items           ShipmentItem[]
  files           ShipmentFile[]
  receipt         ShipmentReceipt?
  statusHistory   ShipmentStatusHistory[]

  @@map("shipments")
}

// Itens de um envio - seção 4.9
model ShipmentItem {
  id          String           @id @default(uuid())
  shipmentId  String           @map("shipment_id")
  description String
  category    String?
  quantity    Decimal          @db.Decimal(10, 2)
  unit        ShipmentItemUnit @default(UND)
  notes       String?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@map("shipment_items")
}

// Arquivos gerados/anexados a um envio (ex: PDF do comprovante) - seção 4.9
model ShipmentFile {
  id          String           @id @default(uuid())
  shipmentId  String           @map("shipment_id")
  type        ShipmentFileType @default(PDF)
  filePath    String           @map("file_path")
  publicToken String           @unique @map("public_token")
  createdAt   DateTime         @default(now()) @map("created_at")

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@map("shipment_files")
}

// Confirmação de recebimento de um envio pelo conferente da unidade de
// destino - seção 4.9
model ShipmentReceipt {
  id          String   @id @default(uuid())
  shipmentId  String   @unique @map("shipment_id")
  confirmedBy String   @map("confirmed_by")
  confirmedAt DateTime @default(now()) @map("confirmed_at")
  notes       String?
  ipAddress   String?  @map("ip_address")

  shipment        Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  confirmedByUser User     @relation(fields: [confirmedBy], references: [id])

  @@map("shipment_receipts")
}

// Timeline de movimentações de status de um envio - seção 4.9
model ShipmentStatusHistory {
  id         String         @id @default(uuid())
  shipmentId String         @map("shipment_id")
  status     ShipmentStatus
  changedAt  DateTime       @default(now()) @map("changed_at")
  changedBy  String?        @map("changed_by")
  notes      String?

  shipment Shipment @relation(fields: [shipmentId], references: [id])

  @@map("shipment_status_history")
}

// Alertas automáticos de vencimento/atraso - seção 4.10. Gerados
// diariamente por job (@Cron) que verifica licenciamento/seguro/CNH,
// agenda de manutenção (revisão/óleo/pneus) e viagens em atraso.
model Alert {
  id            String        @id @default(uuid())
  type          AlertType
  referenceType String        @map("reference_type")
  referenceId   String        @map("reference_id")
  message       String
  severity      AlertSeverity
  dueDate       DateTime?     @map("due_date")
  status        AlertStatus   @default(PENDENTE)
  targetRole    Role?         @map("target_role")
  targetUserId  String?       @map("target_user_id")
  createdAt     DateTime      @default(now()) @map("created_at")

  @@unique([referenceType, referenceId, type, dueDate, targetRole, targetUserId])
  @@map("alerts")
}

// Metas de redução de consumo e cálculo de comissão - seção 4.13
model Goal {
  id              String     @id @default(uuid())
  driverId        String?    @map("driver_id")
  vehicleId       String?    @map("vehicle_id")
  type            GoalType
  period          String // YYYY-MM
  targetValue     Decimal    @map("target_value") @db.Decimal(10, 3)
  actualValue     Decimal?   @map("actual_value") @db.Decimal(10, 3)
  commissionValue Decimal?   @map("commission_value") @db.Decimal(10, 2)
  status          GoalStatus @default(ABERTA)
  createdBy       String?    @map("created_by")
  updatedBy       String?    @map("updated_by")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  driver  Driver?  @relation(fields: [driverId], references: [id])
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])

  @@map("goals")
}

// Relatórios exportáveis (PDF/Excel/CSV) gerados de forma assíncrona via
// fila BullMQ - seção 4.14
model Report {
  id           String       @id @default(uuid())
  type         ReportType
  format       ReportFormat
  filters      Json
  status       ReportStatus @default(PENDING)
  filePath     String?      @map("file_path")
  errorMessage String?      @map("error_message")
  requestedBy  String       @map("requested_by")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  @@map("reports")
}
