// Prisma schema - Sistema de Logistica e Controle de Frota
// Convenção (seção 6 do CLAUDE.md): tabelas/colunas em snake_case via @@map/@map,
// atributos do model em camelCase, enums em UPPER_SNAKE_CASE.

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// Perfis de acesso (RBAC) - seção 4.1
enum Role {
  ADMIN
  COORDENACAO
  MOTORISTA
  FINANCEIRO
}

// Tipos de combustível dos veículos - seção 4.3 / 4.6
enum FuelType {
  GASOLINE
  ETHANOL
  DIESEL
  FLEX
  GNV
}

// Status do registro diário de uso da frota - seção 4.4
enum DailyLogStatus {
  EM_ANDAMENTO
  FINALIZADO
}

// Status da viagem - seção 4.5
enum TripStatus {
  EM_ANDAMENTO
  FINALIZADA
  ATRASADA
}

// Tipo de manutenção - seção 4.7
enum MaintenanceType {
  PREVENTIVA
  CORRETIVA
}

// Categoria de manutenção - define qual campo next* do Vehicle é
// recalculado ao concluir o registro - seção 4.7
enum MaintenanceCategory {
  TROCA_OLEO
  TROCA_PNEUS
  REVISAO_GERAL
  OUTROS
}

// Categoria da ocorrência (classificação ampla, usada em filtros e
// indicadores) - seção 4.8
enum IncidentCategory {
  TRANSITO
  SINISTRO
  MECANICA
  OPERACIONAL
  OUTROS
}

// Tipo da ocorrência (classificação específica - "Exemplos de tipo" da
// seção 4.8: multa, acidente, pane, atraso, dano ao veículo)
enum IncidentType {
  MULTA
  ACIDENTE
  PANE
  ATRASO
  DANO_VEICULO
  OUTROS
}

// Gravidade da ocorrência - seção 4.8
enum IncidentSeverity {
  BAIXA
  MEDIA
  ALTA
  CRITICA
}

// Status do envio (protocolo) - seção 4.9
enum ShipmentStatus {
  PENDENTE
  EM_TRANSITO
  ENTREGUE
  CANCELADO
}

// Tipo de alerta automático - seção 4.10
enum AlertType {
  LICENSING
  INSURANCE
  CNH
  REVIEW
  OIL_CHANGE
  TIRE_CHANGE
  TRIP_DELAYED
}

// Gravidade do alerta - seção 4.10
enum AlertSeverity {
  INFO
  AVISO
  CRITICO
}

// Status do alerta (controle de envio/leitura) - seção 4.10
enum AlertStatus {
  PENDENTE
  ENVIADO
  LIDO
}

// Usuários do sistema - seção 4.1
model User {
  id                  String    @id @default(uuid())
  name                String
  email               String    @unique
  passwordHash        String    @map("password_hash")
  role                Role
  isActive            Boolean   @default(true) @map("is_active")
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  driver        Driver?
  sentShipments Shipment[] @relation("ShipmentSender")

  @@map("users")
}

// Unidades de destino dos envios - seção 4.2 / 4.9 (usado também na Fase 8)
model Unit {
  id        String   @id @default(uuid())
  name      String
  address   String
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  shipments Shipment[]

  @@map("units")
}

// Rotas - seção 4.2
model Route {
  id                       String   @id @default(uuid())
  name                     String
  origin                   String
  destination              String
  estimatedDistanceKm      Decimal  @map("estimated_distance_km") @db.Decimal(10, 2)
  estimatedDurationMinutes Int      @map("estimated_duration_minutes")
  active                   Boolean  @default(true)
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  vehicles  Vehicle[]  @relation("VehicleMainRoute")
  drivers   Driver[]   @relation("DriverDefaultRoute")
  dailyLogs DailyLog[]
  trips     Trip[]

  @@map("routes")
}

// Veículos - seção 4.3
model Vehicle {
  id                  String    @id @default(uuid())
  plate               String    @unique
  fuelType            FuelType  @map("fuel_type")
  tankCapacityLiters  Decimal   @map("tank_capacity_liters") @db.Decimal(10, 2)
  yearModel           Int       @map("year_model")
  mainRouteId         String?   @map("main_route_id")
  acquisitionValue    Decimal   @map("acquisition_value") @db.Decimal(12, 2)
  usefulLifeMonths    Int       @map("useful_life_months")
  residualValue       Decimal   @map("residual_value") @db.Decimal(12, 2)
  currentKm           Decimal   @default(0) @map("current_km") @db.Decimal(10, 1)
  licensingExpiration DateTime? @map("licensing_expiration")
  insuranceExpiration DateTime? @map("insurance_expiration")
  active              Boolean   @default(true)
  // Próximas manutenções previstas - seção 4.7 (base para alertas da Fase 9)
  nextOilChangeKm     Decimal?  @map("next_oil_change_km") @db.Decimal(10, 1)
  nextOilChangeDate   DateTime? @map("next_oil_change_date")
  nextTireChangeKm    Decimal?  @map("next_tire_change_km") @db.Decimal(10, 1)
  nextTireChangeDate  DateTime? @map("next_tire_change_date")
  nextReviewKm        Decimal?  @map("next_review_km") @db.Decimal(10, 1)
  nextReviewDate      DateTime? @map("next_review_date")
  createdBy           String?   @map("created_by")
  updatedBy           String?   @map("updated_by")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  mainRoute    Route?        @relation("VehicleMainRoute", fields: [mainRouteId], references: [id])
  drivers      Driver[]
  dailyLogs    DailyLog[]
  trips        Trip[]
  fuelRecords  Fuel[]
  maintenances Maintenance[]
  incidents    Incident[]

  @@map("vehicles")
}

// Motoristas - seção 4.2
model Driver {
  id             String    @id @default(uuid())
  name           String
  position       String
  vehicleId      String?   @map("vehicle_id")
  currentKm      Decimal   @default(0) @map("current_km") @db.Decimal(10, 1)
  defaultRouteId String?   @map("default_route_id")
  cnhExpiration  DateTime? @map("cnh_expiration")
  userId         String?   @unique @map("user_id")
  active         Boolean   @default(true)
  createdBy      String?   @map("created_by")
  updatedBy      String?   @map("updated_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  vehicle              Vehicle?   @relation(fields: [vehicleId], references: [id])
  defaultRoute         Route?     @relation("DriverDefaultRoute", fields: [defaultRouteId], references: [id])
  user                 User?      @relation(fields: [userId], references: [id])
  dailyLogs            DailyLog[]
  trips                Trip[]
  fuelRecords          Fuel[]
  incidents            Incident[]
  transportedShipments Shipment[] @relation("ShipmentTransporter")

  @@map("drivers")
}

// Registro diário de uso da frota (saída/retorno) - seção 4.4
model DailyLog {
  id                   String         @id @default(uuid())
  vehicleId            String         @map("vehicle_id")
  driverId             String         @map("driver_id")
  routeId              String         @map("route_id")
  departureAt          DateTime       @map("departure_at")
  returnAt             DateTime?      @map("return_at")
  startKm              Decimal        @map("start_km") @db.Decimal(10, 1)
  endKm                Decimal?       @map("end_km") @db.Decimal(10, 1)
  kmDriven             Decimal?       @map("km_driven") @db.Decimal(10, 1)
  totalDurationMinutes Int?           @map("total_duration_minutes")
  avgSpeedKmh          Decimal?       @map("avg_speed_kmh") @db.Decimal(10, 2)
  observations         String?
  status               DailyLogStatus @default(EM_ANDAMENTO)
  createdBy            String?        @map("created_by")
  updatedBy            String?        @map("updated_by")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  driver  Driver  @relation(fields: [driverId], references: [id])
  route   Route   @relation(fields: [routeId], references: [id])

  @@map("daily_logs")
}

// Viagens (trips) - seção 4.5
model Trip {
  id          String     @id @default(uuid())
  vehicleId   String     @map("vehicle_id")
  driverId    String     @map("driver_id")
  routeId     String     @map("route_id")
  status      TripStatus @default(EM_ANDAMENTO)
  destination String
  startKm     Decimal    @map("start_km") @db.Decimal(10, 1)
  endKm       Decimal?   @map("end_km") @db.Decimal(10, 1)
  startedAt   DateTime   @map("started_at")
  finishedAt  DateTime?  @map("finished_at")
  createdBy   String?    @map("created_by")
  updatedBy   String?    @map("updated_by")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  driver  Driver  @relation(fields: [driverId], references: [id])
  route   Route   @relation(fields: [routeId], references: [id])

  @@map("trips")
}

// Abastecimento - seção 4.6
model Fuel {
  id             String   @id @default(uuid())
  vehicleId      String   @map("vehicle_id")
  driverId       String   @map("driver_id")
  liters         Decimal  @db.Decimal(10, 2)
  amountPaid     Decimal  @map("amount_paid") @db.Decimal(10, 2)
  currentKm      Decimal  @map("current_km") @db.Decimal(10, 1)
  fuelType       FuelType @map("fuel_type")
  date           DateTime @default(now())
  consumptionKmL Decimal? @map("consumption_km_l") @db.Decimal(10, 3)
  costPerKm      Decimal? @map("cost_per_km") @db.Decimal(10, 4)
  createdBy      String?  @map("created_by")
  updatedBy      String?  @map("updated_by")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  driver  Driver  @relation(fields: [driverId], references: [id])

  @@map("fuel_records")
}

// Manutenção - seção 4.7
model Maintenance {
  id            String              @id @default(uuid())
  vehicleId     String              @map("vehicle_id")
  type          MaintenanceType
  category      MaintenanceCategory
  km            Decimal             @db.Decimal(10, 1)
  cost          Decimal             @db.Decimal(10, 2)
  description   String
  scheduledDate DateTime?           @map("scheduled_date")
  scheduledKm   Decimal?            @map("scheduled_km") @db.Decimal(10, 1)
  performedDate DateTime?           @map("performed_date")
  createdBy     String?             @map("created_by")
  updatedBy     String?             @map("updated_by")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@map("maintenances")
}

// Ocorrências - seção 4.8
model Incident {
  id           String           @id @default(uuid())
  vehicleId    String           @map("vehicle_id")
  driverId     String           @map("driver_id")
  category     IncidentCategory
  type         IncidentType
  severity     IncidentSeverity
  responsible  String
  cost         Decimal?         @db.Decimal(10, 2)
  observations String
  date         DateTime
  createdBy    String?          @map("created_by")
  updatedBy    String?          @map("updated_by")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  driver  Driver  @relation(fields: [driverId], references: [id])

  @@map("incidents")
}

// Contador atômico para geração do número de protocolo (AAAAMMDD-SEQ) dos
// envios - seção 4.9. Uma linha por dia; "lastSeq" é incrementado via
// `INSERT ... ON CONFLICT DO UPDATE` (atômico mesmo sob concorrência).
model ProtocolCounter {
  date    String @id
  lastSeq Int    @default(0) @map("last_seq")

  @@map("protocol_counters")
}

// Envios de itens entre unidades, identificados por protocolo único - seção 4.9
model Shipment {
  id                String         @id @default(uuid())
  protocolNumber    String         @unique @map("protocol_number")
  destinationUnitId String         @map("destination_unit_id")
  items             Json
  senderId          String         @map("sender_id")
  transporterId     String?        @map("transporter_id")
  observations      String?
  status            ShipmentStatus @default(PENDENTE)
  createdBy         String?        @map("created_by")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  destinationUnit Unit                    @relation(fields: [destinationUnitId], references: [id])
  sender          User                    @relation("ShipmentSender", fields: [senderId], references: [id])
  transporter     Driver?                 @relation("ShipmentTransporter", fields: [transporterId], references: [id])
  statusHistory   ShipmentStatusHistory[]

  @@map("shipments")
}

// Timeline de movimentações de status de um envio - seção 4.9
model ShipmentStatusHistory {
  id         String         @id @default(uuid())
  shipmentId String         @map("shipment_id")
  status     ShipmentStatus
  changedAt  DateTime       @default(now()) @map("changed_at")
  changedBy  String?        @map("changed_by")
  notes      String?

  shipment Shipment @relation(fields: [shipmentId], references: [id])

  @@map("shipment_status_history")
}

// Alertas automáticos de vencimento/atraso - seção 4.10. Gerados
// diariamente por job (@Cron) que verifica licenciamento/seguro/CNH,
// agenda de manutenção (revisão/óleo/pneus) e viagens em atraso.
model Alert {
  id            String        @id @default(uuid())
  type          AlertType
  referenceType String        @map("reference_type")
  referenceId   String        @map("reference_id")
  message       String
  severity      AlertSeverity
  dueDate       DateTime?     @map("due_date")
  status        AlertStatus   @default(PENDENTE)
  targetRole    Role?         @map("target_role")
  targetUserId  String?       @map("target_user_id")
  createdAt     DateTime      @default(now()) @map("created_at")

  @@unique([referenceType, referenceId, type, dueDate])
  @@map("alerts")
}
