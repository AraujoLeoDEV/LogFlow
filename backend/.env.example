# =========================================================
# APP
# =========================================================
APP_NAME=SistemaLogistica
APP_ENV=development
APP_URL=http://localhost:3000
PORT=3000

# =========================================================
# FRONTEND
# =========================================================
FRONTEND_URL=http://localhost:5173

# =========================================================
# DATABASE - POSTGRESQL
# =========================================================
DB_CLIENT=postgresql
DB_HOST=localhost
DB_PORT=5432
DB_NAME=logistica_db
DB_USER=postgres
DB_PASSWORD=changeme

# URL COMPLETA (opcional)
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/logistica_db

# =========================================================
# JWT AUTH
# =========================================================
JWT_SECRET=change_me_to_a_strong_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_to_a_strong_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# =========================================================
# SEGURANÇA - LOGIN
# =========================================================
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# =========================================================
# REDIS (CACHE / FILAS)
# =========================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# =========================================================
# EMAIL
# =========================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Sistema Logistica

# =========================================================
# STORAGE / UPLOADS
# =========================================================
STORAGE_DRIVER=local

UPLOAD_MAX_SIZE=20MB

# AWS S3 (caso utilize)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=sa-east-1
AWS_BUCKET=

# =========================================================
# GOOGLE MAPS / GPS
# =========================================================
GOOGLE_MAPS_API_KEY=

# =========================================================
# SISTEMA DE ALERTAS
# =========================================================
ENABLE_EMAIL_ALERTS=true
ENABLE_PUSH_ALERTS=true
ALERT_CRON_EXPRESSION=0 6 * * *

# =========================================================
# LOGS
# =========================================================
LOG_LEVEL=debug

# =========================================================
# SEGURANÇA
# =========================================================
BCRYPT_ROUNDS=12

# =========================================================
# MÓDULO DE FROTA
# =========================================================
DEFAULT_FUEL_PRICE=6.19
KM_ALERT_OIL_CHANGE=10000
KM_ALERT_MAINTENANCE=5000

# =========================================================
# RELATÓRIOS
# =========================================================
PDF_STORAGE_PATH=./storage/reports

# =========================================================
# WEBSOCKET (tempo real)
# =========================================================
WS_PORT=3001

# =========================================================
# DOCKER
# =========================================================
DOCKER_ENV=true

# =========================================================
# MONITORAMENTO
# =========================================================
SENTRY_DSN=

# =========================================================
# API EXTERNA DE RASTREAMENTO
# =========================================================
TRACKING_API_URL=
TRACKING_API_TOKEN=
