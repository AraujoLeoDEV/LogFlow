# Reverse proxy - Fase 15 (Deploy e Producao).
# APP_DOMAIN e API_DOMAIN sao lidos do ambiente do container caddy
# (definidos em .env.production e injetados via docker-compose.prod.yml).
#
# Servido via Cloudflare Tunnel, que termina o TLS na borda - por isso os
# sites usam http:// aqui (auto-HTTPS do Caddy entraria em conflito/loop
# com o tunnel). default_sni continua necessario para o handshake interno.

{
	default_sni {$APP_DOMAIN_HOST}
}

http://{$APP_DOMAIN} {

	encode gzip
	reverse_proxy frontend:80
}

http://{$API_DOMAIN} {

	encode gzip
	reverse_proxy backend:3000
}
