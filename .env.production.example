# =========================================================
# Variaveis de producao (Fase 15 - Deploy e Producao)
# =========================================================
# Copie este arquivo para `.env.production` (NUNCA versionado - ver .gitignore)
# e preencha com valores reais. Usado por:
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build
#
# Este arquivo serve dois propositos:
# 1) substituicao de variaveis (${VAR}) no docker-compose.prod.yml
# 2) env_file do servico "backend" (variaveis do CLAUDE.md secao 2)

# =========================================================
# DOMINIOS / HTTPS (Caddy com "tls internal" - rede interna)
# =========================================================
# Implantacao em rede interna, sem dominio publico/Let's Encrypt:
# substitua <VM_IP> pelo IP fixo da VM (ex: 10.90.10.50).
# APP_DOMAIN = frontend (porta 443) | API_DOMAIN = backend/API (porta 8443)
APP_DOMAIN=https://<VM_IP>
API_DOMAIN=https://<VM_IP>:8443
# URL da API usada como VITE_API_URL no build do frontend
API_URL=https://<VM_IP>:8443

# =========================================================
# APP
# =========================================================
APP_NAME=SistemaLogistica
APP_ENV=production
APP_URL=https://<VM_IP>:8443
PORT=3000

# =========================================================
# FRONTEND
# =========================================================
FRONTEND_URL=https://<VM_IP>

# =========================================================
# DATABASE - POSTGRESQL
# =========================================================
DB_CLIENT=postgresql
DB_NAME=logistica_db
DB_USER=postgres
DB_PASSWORD=change_me_to_a_strong_db_password

# DB_HOST/DATABASE_URL sao sobrescritos pelo docker-compose.prod.yml
# (apontando para o servico "postgres"), mantidos aqui apenas por
# compatibilidade com backend/.env.example.
DB_HOST=postgres
DB_PORT=5432
DATABASE_URL=postgresql://postgres:change_me_to_a_strong_db_password@postgres:5432/logistica_db

# =========================================================
# JWT AUTH
# =========================================================
JWT_SECRET=change_me_to_a_strong_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_to_a_strong_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# =========================================================
# SEGURANÇA - LOGIN
# =========================================================
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# =========================================================
# SEED - USUÁRIO ADMIN INICIAL (npx prisma db seed)
# =========================================================
SEED_ADMIN_EMAIL=admin@logflow.com
SEED_ADMIN_PASSWORD=change_me_admin_password

# =========================================================
# REDIS (CACHE / FILAS)
# =========================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# =========================================================
# EMAIL
# =========================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Sistema Logistica

# =========================================================
# STORAGE / UPLOADS
# =========================================================
STORAGE_DRIVER=local
UPLOAD_MAX_SIZE=20MB

# AWS S3 (caso utilize)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=sa-east-1
AWS_BUCKET=

# =========================================================
# GOOGLE MAPS / GPS
# =========================================================
GOOGLE_MAPS_API_KEY=

# =========================================================
# SISTEMA DE ALERTAS
# =========================================================
ENABLE_EMAIL_ALERTS=true
ENABLE_PUSH_ALERTS=true
ALERT_CRON_EXPRESSION=0 6 * * *

# =========================================================
# LOGS
# =========================================================
# "production" ativa rotacao diaria via pino-roll (ver app.module.ts),
# gravando em /app/logs (volume backend_logs)
LOG_LEVEL=info

# =========================================================
# SEGURANÇA
# =========================================================
BCRYPT_ROUNDS=12

# =========================================================
# MÓDULO DE FROTA
# =========================================================
DEFAULT_FUEL_PRICE=6.19
KM_ALERT_OIL_CHANGE=10000
KM_ALERT_MAINTENANCE=5000

# =========================================================
# RELATÓRIOS
# =========================================================
PDF_STORAGE_PATH=./storage/reports

# =========================================================
# DOCKER
# =========================================================
DOCKER_ENV=true

# =========================================================
# MONITORAMENTO
# =========================================================
SENTRY_DSN=

# =========================================================
# API EXTERNA DE RASTREAMENTO
# =========================================================
TRACKING_API_URL=
TRACKING_API_TOKEN=

# =========================================================
# BACKUP (Postgres)
# =========================================================
BACKUP_RETENTION_DAYS=7
